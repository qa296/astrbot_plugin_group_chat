{
  "list_mode": {
    "description": "名单模式",
    "type": "string",
    "hint": "blacklist: 黑名单模式(除名单外的群启用); whitelist: 白名单模式(仅名单内的群启用)",
    "default": "blacklist",
    "options": ["blacklist", "whitelist"]
  },
  "groups": {
    "description": "群组名单",
    "type": "list",
    "hint": "根据名单模式，填写需要启用/禁用的群号",
    "default": []
  },
  "state_machine": {
    "description": "心流状态机配置",
    "type": "object",
    "items": {
      "observer_to_flow_threshold": {
        "description": "观察态→沉浸态阈值",
        "type": "float",
        "hint": "群活跃度达到此值时从观察态进入沉浸态",
        "default": 0.4
      },
      "flow_to_active_threshold": {
        "description": "沉浸态→活跃态阈值",
        "type": "float",
        "hint": "相关度达到此值时从沉浸态进入活跃态",
        "default": 0.7
      },
      "max_reply_streak": {
        "description": "最大连续回复数",
        "type": "int",
        "hint": "超过此数量将进入疲劳态",
        "default": 5
      },
      "fatigue_recovery_minutes": {
        "description": "疲劳恢复时间(分钟)",
        "type": "int",
        "default": 5
      }
    }
  },
  "energy_system": {
    "description": "能量系统配置",
    "type": "object",
    "items": {
      "initial_energy": {
        "description": "初始能量",
        "type": "float",
        "default": 0.8
      },
      "energy_cost_base": {
        "description": "基础回复消耗",
        "type": "float",
        "default": 0.1
      },
      "energy_cost_per_char": {
        "description": "每字额外消耗",
        "type": "float",
        "default": 0.0005
      },
      "energy_recovery_rate": {
        "description": "能量恢复速率(/分钟)",
        "type": "float",
        "default": 0.02
      },
      "energy_recovery_on_at": {
        "description": "被@时能量恢复",
        "type": "float",
        "default": 0.3
      }
    }
  },
  "timing": {
    "description": "时机控制配置",
    "type": "object",
    "items": {
      "base_cooldown_seconds": {
        "description": "基础冷却时间(秒)",
        "type": "float",
        "default": 45.0
      },
      "min_reply_delay": {
        "description": "最小回复延迟(秒)",
        "type": "float",
        "default": 1.0
      },
      "max_reply_delay": {
        "description": "最大回复延迟(秒)",
        "type": "float",
        "default": 10.0
      },
      "heartbeat_interval_seconds": {
        "description": "心跳间隔(秒)",
        "type": "float",
        "default": 15.0
      }
    }
  },
  "learning": {
    "description": "学习系统配置",
    "type": "object",
    "items": {
      "enable_online_learning": {
        "description": "启用在线学习",
        "type": "bool",
        "default": true
      },
      "strategy_memory_size": {
        "description": "策略记忆容量",
        "type": "int",
        "default": 1000
      },
      "learning_rate": {
        "description": "学习率",
        "type": "float",
        "default": 0.1
      },
      "discount_factor": {
        "description": "折扣因子",
        "type": "float",
        "default": 0.95
      }
    }
  },
  "reward": {
    "description": "奖励函数配置",
    "type": "object",
    "items": {
      "user_reply": {
        "description": "用户回复奖励",
        "type": "float",
        "default": 0.5
      },
      "user_at_follow": {
        "description": "用户@跟进奖励",
        "type": "float",
        "default": 1.0
      },
      "user_like": {
        "description": "用户点赞奖励(表情回应)",
        "type": "float",
        "default": 0.3
      },
      "ignore_penalty": {
        "description": "被忽略惩罚",
        "type": "float",
        "default": -0.2
      },
      "negative_penalty": {
        "description": "负面反馈惩罚",
        "type": "float",
        "default": -1.0
      },
      "feedback_detection_window_seconds": {
        "description": "反馈检测窗口(秒)",
        "type": "int",
        "default": 60
      }
    }
  },
  "performance_mode": {
    "description": "性能模式",
    "type": "string",
    "hint": "lightweight: 轻量模式(最少LLM调用); balanced: 平衡模式; quality: 质量优先(更多LLM调用)",
    "default": "balanced",
    "options": ["lightweight", "balanced", "quality"]
  },
  "air_reading": {
    "description": "读空气功能配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用读空气功能",
        "type": "bool",
        "default": true
      },
      "no_reply_marker": {
        "description": "不回复标记",
        "type": "string",
        "hint": "LLM返回包含此标记时跳过回复",
        "default": "<NO_RESPONSE>"
      }
    }
  },
  "offline_distillation": {
    "description": "离线蒸馏配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用离线蒸馏",
        "type": "bool",
        "default": true
      },
      "schedule_time": {
        "description": "蒸馏触发时间",
        "type": "string",
        "hint": "每天固定时间触发，格式HH:MM",
        "default": "03:00"
      },
      "max_messages": {
        "description": "每次蒸馏最大消息数",
        "type": "int",
        "hint": "每次蒸馏处理的最大消息数量",
        "default": 1000
      },
      "similarity": {
        "description": "相似度匹配配置",
        "type": "object",
        "items": {
          "threshold": {
            "description": "相似度阈值",
            "type": "float",
            "hint": "相似度达到此值时触发回复",
            "default": 0.6
          },
          "context_window": {
            "description": "上下文窗口大小",
            "type": "int",
            "hint": "用于匹配的消息数量",
            "default": 10
          }
        }
      },
      "rules": {
        "description": "规则配置",
        "type": "object",
        "items": {
          "max_similarity_rules": {
            "description": "最大相似度规则数",
            "type": "int",
            "default": 500
          },
          "max_regex_rules": {
            "description": "最大正则规则数",
            "type": "int",
            "default": 100
          }
        }
      }
    }
  }
}
